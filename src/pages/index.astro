---
import { getCollection, getEntry, render } from 'astro:content';
import HomeNotes from '../components/HomeNotes.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { sortNotes } from '../lib/notes';

const page = await getEntry('pages', 'home');

if (!page) {
  throw new Error('Home page content is missing');
}

const { Content } = await render(page);
const recentNotes = sortNotes(await getCollection('notes', ({ data }) => !data.draft)).slice(0, 3);
---

<PageLayout
  title={page.data.title}
  documentTitle="Борис Евдеев"
  description={page.data.description}
  showTitle={false}
  class="home-page"
>
  <div class="home-intro">
    <h1 class="visually-hidden">Борис Евдеев</h1>
    <Content />
  </div>
  <HomeNotes notes={recentNotes} />
</PageLayout>
