---
import { getCollection } from 'astro:content';
import HomeCareer from '../components/HomeCareer.astro';
import HomeNotes from '../components/HomeNotes.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { getFeaturedCareer } from '../lib/career';
import { sortNotes } from '../lib/notes';
import { getPageContent } from '../lib/pages';

const { page, Content } = await getPageContent('home');
const recentNotes = sortNotes(await getCollection('notes', ({ data }) => !data.draft)).slice(0, 3);
const featuredCareer = getFeaturedCareer(await getCollection('career'));
---

<PageLayout
  title={page.data.title}
  documentTitle="Борис Евдеев"
  description={page.data.description}
  showTitle={false}
  class="home-page"
>
  <div class="home-intro">
    <h1 class="visually-hidden">Борис Евдеев</h1>
    <Content />
  </div>
  <HomeCareer career={featuredCareer} />
  <HomeNotes notes={recentNotes} />
</PageLayout>
