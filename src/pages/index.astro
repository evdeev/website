---
import BaseLayout from '../layouts/BaseLayout.astro';
import { author } from '../lib/author';
import { getPageContent } from '../lib/pages';
import { typografText } from '../lib/typography.mjs';

const { page } = await getPageContent('home');
const lead = page.data.lead ?? 'Создаю и развиваю цифровые кредитные решения для бизнеса. Превращаю сложные банковские процессы в понятные сервисы.';
const personal = page.data.personal;
const sections = [
  {
    title: 'Заметки',
    description: 'Мысли и наблюдения',
    href: '/notes',
    analyticsEvent: 'nav_click',
    analyticsSection: 'home_sections',
  },
  {
    title: 'Опыт',
    description: 'Профессиональный путь',
    href: '/career',
    analyticsEvent: 'career_click',
    analyticsSection: 'home_sections',
  },
  {
    title: 'Списки',
    description: 'Интересы и рекомендации',
    href: '/lists',
    analyticsEvent: 'nav_click',
    analyticsSection: 'home_sections',
  },
];
---

<BaseLayout
  documentTitle="Борис Евдеев"
  description={page.data.description}
  showHeader={false}
  showFooter={false}
  bodyClass="home-body"
>
  <article class="home-page" id="top">
    <header class="hero" aria-label={author.name}>
      <span class="mascot hero__mascot" aria-hidden="true"></span>
      <h1 class="hero__name">{author.name}</h1>
      <p class="hero__lead">{typografText(lead)}</p>
      {personal && <p class="hero__personal">{typografText(personal)}</p>}
    </header>

    <nav class="section-nav" aria-label="Разделы сайта">
      <ul class="section-nav__list">
        {sections.map((section) => (
          <li>
            <a
              class="section-link"
              href={section.href}
              data-analytics-event={section.analyticsEvent}
              data-analytics-section={section.analyticsSection}
              data-analytics-content-type="navigation"
            >
              <span class="section-link__title">{section.title}</span>
              <span class="section-link__description">{section.description}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <footer class="home-footer">
      <address class="home-footer__identity">
        <strong class="home-footer__name">{author.name}</strong>
        <span>{author.location}</span>
        <span class="home-footer__links">
          <a
            href={author.contacts.telegram}
            data-analytics-event="telegram_click"
            data-analytics-section="footer"
            data-analytics-content-type="contact"
          >Телеграм</a>
          <span class="home-footer__separator" aria-hidden="true">·</span>
          <a
            href={author.contacts.email}
            data-analytics-event="email_click"
            data-analytics-section="footer"
            data-analytics-content-type="contact"
          >Почта</a>
        </span>
      </address>
      <div class="home-footer__meta">
        <a
          href="/policy"
          data-analytics-event="nav_click"
          data-analytics-section="footer"
          data-analytics-content-type="policy"
        >Политика конфиденциальности</a>
        <a
          class="home-footer__top"
          href="#top"
          data-analytics-event="back_to_top_click"
          data-analytics-section="footer"
          data-analytics-content-type="navigation"
        >Наверх ↑</a>
      </div>
    </footer>
  </article>
</BaseLayout>
