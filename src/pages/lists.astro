---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { lists } from '../lib/lists';
import { getPageContent } from '../lib/pages';

const { page, Content } = await getPageContent('lists');
const activeLists = lists.filter((list) => list.href);
const upcomingLists = lists.filter((list) => !list.href);
---

<BaseLayout
  documentTitle="Списки Бориса Евдеева"
  description={page.data.description}
>
  <section class="content lists-page">
    <SectionTitle title={page.data.title} />
    <div class="lists-intro">
      <Content />
    </div>
    <ul class="lists-list">
      {activeLists.map((list) => (
        <li class="list-section-item">
          <h2 class="list-section-title"><a href={list.href}>{list.title}</a></h2>
          <p class="list-section-description">{list.description}</p>
        </li>
      ))}
    </ul>
    <section class="upcoming-lists" aria-labelledby="upcoming-lists-title">
      <h2 class="lists-subtitle" id="upcoming-lists-title">Скоро</h2>
      <ul class="lists-list">
        {upcomingLists.map((list) => (
          <li class="list-section-item is-upcoming">
            <h3 class="list-section-title">{list.title}</h3>
            <p class="list-section-description">{list.description}</p>
          </li>
        ))}
      </ul>
    </section>
  </section>
</BaseLayout>
