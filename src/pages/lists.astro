---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/intro/PageIntro.astro';
import CollectionList from '../components/lists/CollectionList.astro';
import { collections } from '../lib/collections';
import { getPageContent } from '../lib/pages';

const { page, Content, hasContent } = await getPageContent('lists');
const activeLists = collections.filter((list) => list.href);
const upcomingLists = collections.filter((list) => !list.href);
---

<BaseLayout
  documentTitle="Списки Бориса Евдеева"
  description={page.data.description}
>
  <section class="content lists-page">
    <PageIntro title={page.data.title} description={page.data.intro} />
    {hasContent && (
      <div class="page-body">
        <Content />
      </div>
    )}
    <CollectionList collections={activeLists} />
    <section class="upcoming-lists" aria-labelledby="upcoming-lists-title">
      <h2 class="lists-subtitle" id="upcoming-lists-title">Скоро</h2>
      <CollectionList collections={upcomingLists} headingLevel="h3" upcoming />
    </section>
  </section>
</BaseLayout>
