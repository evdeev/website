---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { lists } from '../lib/lists';
---

<BaseLayout
  documentTitle="Списки Бориса Евдеева"
  description="Списки Бориса Евдеева: игры, фильмы и желания."
>
  <section class="content lists-page">
    <SectionTitle title="Списки" />
    <p class="lists-intro">Здесь будут списки книг, фильмов, игр и вещей, которые хочется сохранить.</p>
    <ul class="lists-list">
      {lists.map((list) => (
        <li>
          {list.href
            ? <a class="list-name" href={list.href}>{list.title}</a>
            : <span class="list-name">{list.title}</span>}
          {list.status && <span class="list-status">{list.status}</span>}
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
