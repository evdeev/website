---
import { getCollection, render } from 'astro:content';
import CareerTimelineItem from '../components/CareerTimelineItem.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { sortCareerEntries } from '../lib/career';

const careerEntries = sortCareerEntries(await getCollection('career'));
const timeline = await Promise.all(careerEntries.map(async (career) => ({
  career,
  Content: (await render(career)).Content,
})));
---

<PageLayout title="Карьера" description="Профессиональный путь Бориса Евдеева: от графического дизайна и банковских операций до развития цифровых кредитных продуктов.">
  <div class="career-intro">
    <p>Я начал работать ещё в школе и за это время прошёл путь от графического дизайна и сопровождения банковских операций до руководителя развития цифровых кредитных продуктов и сервисов для бизнеса.</p>
    <p>Сейчас в Альфа-Банке отвечаю за развитие двух кредитных направлений: B2B-кредитование и кредитование селлеров на маркетплейсах.</p>
    <p>Ниже — основные этапы этого пути.</p>
  </div>
  <ol class="career-timeline">
    {timeline.map(({ career, Content }) => (
      <CareerTimelineItem career={career}>
        <Content />
      </CareerTimelineItem>
    ))}
  </ol>
</PageLayout>
