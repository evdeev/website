---
import { getCollection, render } from 'astro:content';
import CareerItem from '../components/career/CareerItem.astro';
import CareerTimeline from '../components/career/CareerTimeline.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { sortCareerEntries } from '../lib/career';
import { getPageContent } from '../lib/pages';
import { typografText } from '../lib/typography.mjs';

const { page, Content: PageContent, hasContent } = await getPageContent('career');
const careerEntries = sortCareerEntries(await getCollection('career')).toReversed();
const timeline = await Promise.all(careerEntries.map(async (career) => ({
  career,
  Content: (await render(career)).Content,
})));
---

<PageLayout
  title={page.data.title}
  description={page.data.description}
  intro={page.data.intro}
  class="career-page"
  siteNavSection="career"
  siteNavDepth="section"
>
  {hasContent && (
    <div class="page-body">
      <PageContent />
    </div>
  )}
  <CareerTimeline>
    {timeline.map(({ career, Content }) => (
      <CareerItem career={career}>
        <Content />
      </CareerItem>
    ))}
  </CareerTimeline>
  {page.data.afterword && (
    <div class="page-body career-afterword">
      <p>{typografText(page.data.afterword)}</p>
    </div>
  )}
</PageLayout>
