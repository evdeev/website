---
import { getCollection, render } from 'astro:content';
import CareerTimelineItem from '../components/CareerTimelineItem.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { sortCareerEntries } from '../lib/career';

const careerEntries = sortCareerEntries(await getCollection('career'));
const timeline = await Promise.all(careerEntries.map(async (career) => ({
  career,
  Content: (await render(career)).Content,
})));
---

<PageLayout title="Карьера" description="Профессиональный опыт и проекты.">
  <ol class="career-timeline">
    {timeline.map(({ career, Content }) => (
      <CareerTimelineItem career={career}>
        <Content />
      </CareerTimelineItem>
    ))}
  </ol>
</PageLayout>
