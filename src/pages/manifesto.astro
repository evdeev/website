---
import PageIntro from '../components/PageIntro.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { getPageContent } from '../lib/pages';

const { page, Content } = await getPageContent('manifesto');
---

<PageLayout
  title={page.data.title}
  documentTitle={`${page.data.title} Бориса Евдеева`}
  description={page.data.description}
  class="manifesto-page"
  noindex
>
  {page.data.intro && <PageIntro text={page.data.intro} />}
  <div class="page-body">
    <Content />
  </div>
</PageLayout>
