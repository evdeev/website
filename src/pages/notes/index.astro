---
import { getCollection } from 'astro:content';
import PageIntro from '../../components/intro/PageIntro.astro';
import NoteCard from '../../components/notes/NoteCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortNotes } from '../../lib/notes';
import { getPageContent } from '../../lib/pages';
import { siteConfig } from '../../site.config';

const { page, Content, hasContent } = await getPageContent('notes');
const notes = sortNotes(await getCollection('notes', ({ data }) => !data.draft));
const { initialVisibleCount } = siteConfig.notes;
const hasHiddenNotes = notes.length > initialVisibleCount;
---

<BaseLayout
  documentTitle="Заметки Бориса Евдеева"
  description={page.data.description}
>
  <section class="content notes-page">
    <PageIntro title={page.data.title} description={page.data.intro} />
    {hasContent && (
      <div class="page-body">
        <Content />
      </div>
    )}
    <ol class="note-listing-list notes-list">
      {notes.map((note, index) => (
        <NoteCard
          note={note}
          headingLevel="h2"
          analyticsSection="notes"
          class={index >= initialVisibleCount ? 'is-hidden' : undefined}
        />
      ))}
    </ol>
    {hasHiddenNotes && <button class="show-more-notes" type="button">Показать ещё ↓</button>}
  </section>
  <script>
    const button = document.querySelector('.show-more-notes');

    button?.addEventListener('click', () => {
      document.querySelectorAll('.notes-list .is-hidden').forEach((note) => {
        note.classList.remove('is-hidden');
      });
      button.remove();
    });
  </script>
</BaseLayout>
