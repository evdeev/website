---
import BaseLayout from './BaseLayout.astro';
import PageIntro from '../components/intro/PageIntro.astro';

interface Props {
  title: string;
  description: string;
  documentTitle?: string;
  intro?: string;
  showTitle?: boolean;
  class?: string;
  noindex?: boolean;
  showHeader?: boolean;
  showFooter?: boolean;
  bodyClass?: string;
}

const {
  title,
  description,
  documentTitle = `${title} Бориса Евдеева`,
  intro,
  showTitle = true,
  class: className,
  noindex = false,
  showHeader = true,
  showFooter = true,
  bodyClass,
} = Astro.props;
---

<BaseLayout
  documentTitle={documentTitle}
  description={description}
  noindex={noindex}
  showHeader={showHeader}
  showFooter={showFooter}
  bodyClass={bodyClass}
>
  <article class:list={['content', 'page-content', className]}>
    {showTitle && <PageIntro title={title} description={intro} />}
    <slot />
  </article>
</BaseLayout>
