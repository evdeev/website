---
import BaseLayout from './BaseLayout.astro';
import { typografText } from '../lib/typography.mjs';

interface Props {
  title: string;
  description: string;
  documentTitle?: string;
  showTitle?: boolean;
  class?: string;
}

const { title, description, documentTitle = `${title} Бориса Евдеева`, showTitle = true, class: className } = Astro.props;
const displayTitle = typografText(title);
---

<BaseLayout documentTitle={documentTitle} description={description}>
  <article class:list={['content', 'page-content', className]}>
    {showTitle && <h1>{displayTitle}</h1>}
    <slot />
  </article>
</BaseLayout>
