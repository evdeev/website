---
import BaseLayout from './BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { typografText } from '../lib/typography.mjs';

interface Props {
  title: string;
  description: string;
  documentTitle?: string;
  showTitle?: boolean;
  class?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  documentTitle = `${title} Бориса Евдеева`,
  showTitle = true,
  class: className,
  noindex = false,
} = Astro.props;
const displayTitle = typografText(title);
---

<BaseLayout documentTitle={documentTitle} description={description} noindex={noindex}>
  <article class:list={['content', 'page-content', className]}>
    {showTitle && <SectionTitle title={displayTitle} />}
    <slot />
  </article>
</BaseLayout>
