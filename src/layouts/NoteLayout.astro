---
import BaseLayout from './BaseLayout.astro';
import NoteHeader from '../components/notes/NoteHeader.astro';
import NoteNavigation from '../components/notes/NoteNavigation.astro';
import Prose from '../components/notes/Prose.astro';
import RelatedNotes from '../components/notes/RelatedNotes.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  description: string;
  intro?: string;
  created: Date;
  tags: string[];
  note: CollectionEntry<'notes'>;
  nextNote?: CollectionEntry<'notes'>;
  previousNote?: CollectionEntry<'notes'>;
}

const { title, description, intro, created, tags, note, nextNote, previousNote } = Astro.props;
const noteSlug = Astro.url.pathname.replace(/^\/notes\//, '').replace(/\/$/, '');
---

<BaseLayout documentTitle={title} description={description} analyticsNoteSlug={noteSlug}>
  <article class="content note-page">
    <NoteHeader title={title} description={description} intro={intro} created={created} tags={tags} />
    <Prose>
      <slot />
    </Prose>
    <RelatedNotes currentNote={note} />
    <NoteNavigation nextNote={nextNote} previousNote={previousNote} />
  </article>
</BaseLayout>
