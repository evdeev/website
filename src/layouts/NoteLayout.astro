---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { typografText } from '../lib/typography.mjs';

interface Props {
  title: string;
  description: string;
  created: Date;
  tags: string[];
  nextNote?: CollectionEntry<'notes'>;
  previousNote?: CollectionEntry<'notes'>;
}

const { title, description, created, tags, nextNote, previousNote } = Astro.props;
const displayTitle = typografText(title);
const displayDescription = typografText(description);
const formattedDate = new Intl.DateTimeFormat('ru-RU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(created);
---

<BaseLayout documentTitle={title} description={description}>
  <article class="content note-content">
    <header class="note-header">
      <p class="note-date"><time datetime={created.toISOString()}>{formattedDate}</time></p>
      <h1>{displayTitle}</h1>
      <p class="note-description">{displayDescription}</p>
      {tags.length > 0 && <p class="note-tags">{tags.map((tag) => `#${tag}`).join(' ')}</p>}
    </header>
    <slot />
    <footer class="note-navigation">
      <nav class="note-neighbors" aria-label="Соседние заметки">
        {previousNote && (
          <a class="note-neighbor-link previous-note" href={`/notes/${previousNote.data.slug}`}>
            <span class="note-neighbor-label">← Предыдущая заметка</span>
            <span>{typografText(previousNote.data.title)}</span>
          </a>
        )}
        {nextNote && (
          <a class="note-neighbor-link next-note" href={`/notes/${nextNote.data.slug}`}>
            <span class="note-neighbor-label">Следующая заметка →</span>
            <span>{typografText(nextNote.data.title)}</span>
          </a>
        )}
      </nav>
      <a class="section-link all-notes-link" href="/notes">Все заметки ↓</a>
    </footer>
  </article>
</BaseLayout>
