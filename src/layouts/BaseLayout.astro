---
import '../styles/global.css';
import { typografText } from '../lib/typography.mjs';

interface Props {
  documentTitle: string;
  description: string;
  showBackToTop?: boolean;
}

const { documentTitle, description, showBackToTop = false } = Astro.props;
const displayTitle = typografText(documentTitle);
const displayDescription = typografText(description);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={displayDescription} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>Б</text></svg>" />
    <meta name="generator" content={Astro.generator} />
    <title>{displayTitle}</title>
  </head>
  <body>
    <header class="site-header" id="top">
      <nav class="site-nav" aria-label="Основная навигация">
        <a class="site-name" href="/">Борис Евдеев</a>
        <div class="site-links">
          <a href="/notes">Заметки</a>
          <a href="/career">Карьера</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>© {new Date().getFullYear()} Борис Евдеев</p>
      {showBackToTop && (
        <a
          class="back-to-top"
          href="#top"
        >
          Наверх ↑
        </a>
      )}
      {showBackToTop && <span aria-hidden="true"></span>}
    </footer>
  </body>
</html>
