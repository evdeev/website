---
import globalStyles from '../styles/global.css?inline';
import { typografText } from '../lib/typography.mjs';
import Footer from '../components/navigation/Footer.astro';
import Header from '../components/navigation/Header.astro';
import SiteNav, { type SiteNavDepth, type SiteNavSection } from '../components/navigation/SiteNav.astro';
import YandexMetrika from '../components/YandexMetrika.astro';

interface Props {
  documentTitle: string;
  description: string;
  analyticsNoteSlug?: string;
  noindex?: boolean;
  showHeader?: boolean;
  showFooter?: boolean;
  bodyClass?: string;
  siteNavSection?: SiteNavSection;
  siteNavDepth?: SiteNavDepth;
}

const {
  documentTitle,
  description,
  analyticsNoteSlug,
  noindex = false,
  showHeader = true,
  showFooter = true,
  bodyClass,
  siteNavSection,
  siteNavDepth = 'section',
} = Astro.props;
const displayTitle = typografText(documentTitle);
const displayDescription = typografText(description);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const showSiteNav = Boolean(siteNavSection);
const shouldShowHeader = showHeader && !showSiteNav;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={displayDescription} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon-32x32-20260610.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-20260610.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon-20260610.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon-20260610.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{displayTitle}</title>
    <style is:inline set:html={globalStyles}></style>
  </head>
  <body class:list={[bodyClass, showSiteNav && 'has-site-section-nav']}>
    {showSiteNav && <SiteNav section={siteNavSection} depth={siteNavDepth} placement="desktop" />}
    {showSiteNav && <SiteNav section={siteNavSection} depth={siteNavDepth} placement="mobile-home" />}
    {shouldShowHeader && <Header />}
    <main>
      <slot />
    </main>
    {showSiteNav && <SiteNav section={siteNavSection} depth={siteNavDepth} placement="mobile" />}
    {showFooter && <Footer />}
    <YandexMetrika noteSlug={analyticsNoteSlug} />
  </body>
</html>
