---
import type { CollectionEntry } from 'astro:content';
import { formatPlaythroughs } from '../../lib/games';
import { typografText } from '../../lib/typography.mjs';

interface Props {
  game: CollectionEntry<'games'>;
}

const { game } = Astro.props;
const { title, developers, releaseYear, rating, status, playthroughs, cover, favorite = false } = game.data;
const metadata = [
  rating !== undefined && `${rating}/10`,
  status,
  playthroughs !== undefined && formatPlaythroughs(playthroughs),
].filter(Boolean);
---

<li class="game-list-item">
  <div class="game-cover-frame">
    <img class="game-cover" src={cover} alt="" width="240" height="320" loading="lazy" decoding="async" />
  </div>
  <div class="game-content">
    <h2 class:list={['favorite-title', favorite && 'has-favorite']}>{typografText(title)}</h2>
    <p class="game-developer">
      {developers.map((developer, index) => (
        <>
          {index > 0 && ', '}
          <a
            href={developer.url}
            data-analytics-event="external_link_click"
            data-analytics-section="games"
            data-analytics-content-type="developer"
          >{developer.name}</a>
        </>
      ))}
      <span aria-hidden="true"> · </span>
      <time datetime={String(releaseYear)}>{releaseYear}</time>
    </p>
    {metadata.length > 0 && <p class="game-meta">{metadata.join(' · ')}</p>}
  </div>
</li>
