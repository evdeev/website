---
import type { Collection } from '../../lib/domain';
import { typografText } from '../../lib/typography.mjs';

interface Props {
  collection: Collection;
  headingLevel?: 'h2' | 'h3';
  upcoming?: boolean;
}

const { collection, headingLevel: Heading = 'h2', upcoming = false } = Astro.props;
---

<li class:list={['list-section-item', { 'is-upcoming': upcoming }]}>
  {collection.href ? (
    <a
      class="section-link"
      href={collection.href}
      data-analytics-event="list_click"
      data-analytics-section="lists"
      data-analytics-content-type="list"
    >
      <Heading class="section-link__title">{typografText(collection.title)}</Heading>
      <span class="section-link__description">{typografText(collection.description)}</span>
    </a>
  ) : (
    <div class="section-link">
      <Heading class="section-link__title">{typografText(collection.title)}</Heading>
      <span class="section-link__description">{typografText(collection.description)}</span>
    </div>
  )}
</li>
