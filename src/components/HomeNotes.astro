---
import type { CollectionEntry } from 'astro:content';
import { formatNoteDate } from '../lib/notes';
import { typografText } from '../lib/typography.mjs';

interface Props {
  notes: CollectionEntry<'notes'>[];
}

const { notes } = Astro.props;
---

<section class="home-notes" aria-labelledby="home-notes-title">
  <h2 id="home-notes-title">Заметки</h2>
  <ol class="home-notes-list">
    {notes.map((note) => (
      <li>
        <h3><a href={`/notes/${note.data.slug}`}>{typografText(note.data.title)}</a></h3>
        <p class="home-note-description">{typografText(note.data.description)}</p>
        <p class="home-note-date">
          <time datetime={note.data.created.toISOString()}>{formatNoteDate(note.data.created)}</time>
        </p>
      </li>
    ))}
  </ol>
  <a class="all-notes-link" href="/notes">Все заметки →</a>
</section>
