---
import type { CollectionEntry } from 'astro:content';
import NoteListItem from './NoteListItem.astro';

interface Props {
  notes: CollectionEntry<'notes'>[];
}

const { notes } = Astro.props;
---

<section class="home-notes" aria-labelledby="home-notes-title">
  <h2 id="home-notes-title">Заметки</h2>
  <ol class="note-listing-list">
    {notes.map((note) => (
      <NoteListItem note={note} headingLevel="h3" analyticsSection="home_notes" />
    ))}
  </ol>
  <a
    class="all-notes-link"
    href="/notes"
    data-analytics-event="nav_click"
    data-analytics-section="home_notes"
    data-analytics-content-type="navigation"
  >Все заметки →</a>
</section>
