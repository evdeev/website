---
import type { CollectionEntry } from 'astro:content';
import { formatCareerPeriod } from '../lib/career';
import { typografText } from '../lib/typography.mjs';

interface Props {
  career: CollectionEntry<'career'>;
}

const { career } = Astro.props;
const companyTitle = typografText(career.data.title);
---

<li class="career-timeline-item">
  <div class="career-timeline-meta">
    <p class="career-company-line">
      {career.data.company_url
        ? (
          <a
            class="career-company"
            href={career.data.company_url}
            data-analytics-event="career_click"
            data-analytics-section="career"
            data-analytics-content-type="company"
          >{companyTitle}</a>
        )
        : <span class="career-company">{companyTitle}</span>}, {typografText(career.data.location)}
    </p>
    <p class="career-period">{formatCareerPeriod(career.data.start, career.data.end)}</p>
  </div>
  <div class="career-timeline-content">
    <span class="career-timeline-marker" aria-hidden="true"></span>
    <h2>{typografText(career.data.headline)}</h2>
    {career.data.official_role && <p class="career-official-role">{typografText(career.data.official_role)}</p>}
    <p class="career-summary">{typografText(career.data.summary)}</p>
    <div class="career-details">
      <slot />
    </div>
  </div>
</li>
