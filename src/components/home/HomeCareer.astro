---
import type { CollectionEntry } from 'astro:content';
import SectionPreview from './SectionPreview.astro';
import { typografText } from '../../lib/typography.mjs';

interface Props {
  career: CollectionEntry<'career'>;
}

const { career } = Astro.props;
const summary = career.data.home_summary ?? career.data.summary;
---

<SectionPreview
  class="home-career"
  title="Карьера"
  titleId="home-career-title"
  action={{
    href: '/career',
    label: 'Весь опыт',
    analyticsEvent: 'career_click',
    analyticsSection: 'home_career',
    analyticsContentType: 'career',
  }}
>
  <p class="home-career-current">Сейчас — {typografText(career.data.title)}</p>
  <p class="home-career-summary">{typografText(summary)}</p>
</SectionPreview>
